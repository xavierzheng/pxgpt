# PXGPT Environment Configuration
# Copy this file to .env and fill in your API keys

# Anthropic API Key
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Google AI API Key
# Get your key from: https://ai.google.dev/
GOOGLE_API_KEY=your_google_key_here

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434

# Default Provider
# Options: anthropic, openai, google, ollama
DEFAULT_PROVIDER=anthropic

# ── Anthropic model ────────────────────────────────────────────────────────────
# claude-sonnet-5 is the default.  Change here to switch globally.
ANTHROPIC_MODEL=claude-sonnet-5

# ── Sync API settings ──────────────────────────────────────────────────────────
MAX_RETRIES=3
TIMEOUT=300
# Temperature — only applied when thinking is OFF (Stage 1 / analyze / schema).
# When output_config.effort is set the API forces its default; sending a custom
# value causes a 400 error.  The guard is enforced automatically.
TEMPERATURE=0.5
# Max tokens for sync (analyze / schema) calls — claude-sonnet-4-6 supports 64 k.
MAX_TOKENS=16384

# ── Batch API settings ─────────────────────────────────────────────────────────
# Per-request token budgets for batch stages.
STAGE1_MAX_TOKENS=16384
STAGE3_MAX_TOKENS=16384

# Adaptive thinking effort for Stage 3 and the schema command.
# Values: low | medium | high | xhigh | max
# Set to empty string to disable thinking.
STAGE3_EFFORT=medium

# Set to true to add the output-300k-2026-03-24 beta header on Stage 1 batches,
# raising the per-response output cap from 64 k to 300 k tokens.
BATCH_300K_OUTPUT=false

# Number of parallel image upload threads for the Files API.
UPLOAD_CONCURRENCY=10

# Seconds to sleep after a 429 rate-limit error.
RATE_LIMIT_SLEEP=60
